# Copy this file to .env and fill in the values before running docker compose.
#
#   cp .env.example .env
#
# Generate a signing key:
#   openssl rand -hex 32

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# 32-byte hex seed used to sign client tokens. Keep this secret.
# Rotate it to invalidate all existing tokens.
MERIDIAN_SIGNING_KEY=

# ---------------------------------------------------------------------------
# Optional — single-node (default: sled embedded storage)
# ---------------------------------------------------------------------------

# TCP bind address (default: 0.0.0.0:3000)
# MERIDIAN_BIND=0.0.0.0:3000

# Data directory for sled storage (default: ./data)
# MERIDIAN_DATA_DIR=/data

# Unique node ID — derived from hostname+port if unset
# MERIDIAN_NODE_ID=1

# ---------------------------------------------------------------------------
# Optional — PostgreSQL storage + pg-sync (docker compose --profile pg up)
# ---------------------------------------------------------------------------

# DATABASE_URL=postgres://meridian:meridian@postgres:5432/meridian

# Replication connection for WAL stream (large payloads > 8 KB)
# MERIDIAN_WAL_CONNSTR=postgres://meridian:meridian@postgres:5432/meridian
# MERIDIAN_WAL_SLOT=meridian_wal
# MERIDIAN_WAL_PUB=meridian_pub

# ---------------------------------------------------------------------------
# Optional — cluster mode (docker compose -f docker-compose.cluster.yml up)
# ---------------------------------------------------------------------------

# Redis URL — enables Redis Pub/Sub cluster transport (--features cluster)
# REDIS_URL=redis://redis:6379

# Gossip interval in seconds (default: 30)
# MERIDIAN_ANTI_ENTROPY_SECS=30

# HTTP cluster peers — alternative to Redis (--features cluster-http)
# MERIDIAN_PEERS=http://meridian-2:3000,http://meridian-3:3000

# ---------------------------------------------------------------------------
# Optional — S3 WAL archive (--features wal-archive-s3)
# ---------------------------------------------------------------------------

# S3_BUCKET=my-meridian-wal
# S3_ENDPOINT=https://my-account.r2.cloudflarestorage.com   # R2 / MinIO / LocalStack
# S3_REGION=us-east-1
# S3_KEY_PREFIX=wal/
# WAL_SEGMENT_SIZE=500

# ---------------------------------------------------------------------------
# Optional — webhooks
# ---------------------------------------------------------------------------

# MERIDIAN_WEBHOOK_URL=https://my-app.example.com/hooks/meridian
# MERIDIAN_WEBHOOK_SECRET=my-hmac-secret
