{
  "name": "meridian-devtools",
  "version": "1.4.1",
  "description": "React devtools overlay for Meridian CRDT state",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint ./src",
    "format": "biome format --write ./src"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/react": "^19.0.0",
    "meridian-sdk": "workspace:*",
    "typescript": "^6.0.0"
  },
  "peerDependencies": {
    "effect": ">=3.21.0",
    "meridian-sdk": ">=1.0.0",
    "react": "^19.0.0",
    "typescript": ">=5.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Chahine-tech/meridian.git",
    "directory": "packages/devtools"
  }
}
