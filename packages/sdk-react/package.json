{
  "name": "meridian-react",
  "version": "1.3.0",
  "description": "React hooks for Meridian CRDT server",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint ./src",
    "format": "biome format --write ./src"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/react": "^19.0.0",
    "meridian-sdk": "workspace:*",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "effect": "^3.21.0"
  },
  "peerDependencies": {
    "meridian-sdk": ">=1.0.0",
    "react": "^19.0.0",
    "typescript": ">=5.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Chahine-tech/meridian.git",
    "directory": "packages/sdk-react"
  },
  "homepage": "https://github.com/Chahine-tech/meridian#readme",
  "bugs": {
    "url": "https://github.com/Chahine-tech/meridian/issues"
  }
